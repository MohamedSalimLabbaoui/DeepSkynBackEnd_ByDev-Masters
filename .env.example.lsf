# ============================================================================
# Sign Language Translation (LSF) Configuration
# ============================================================================

# URL du microservice Python FastAPI
SIGN_TRANSLATION_SERVICE_URL=http://localhost:8000

# Langues supportées (ISO 639-1)
SUPPORTED_LANGUAGES=fr,en

# Timeout pour les appels au microservice (en ms)
TRANSLATION_SERVICE_TIMEOUT=30000

# Nombre de tentatives en cas d'erreur
TRANSLATION_MAX_RETRIES=3

# Délai entre les retries (en ms)
TRANSLATION_RETRY_DELAY=1000

# ============================================================================
# Optional: Cache Configuration (si cache est activé)
# ============================================================================

# Redis URL (optionnel)
# REDIS_URL=redis://localhost:6379

# TTL du cache en secondes (24 heures)
# CACHE_TTL=86400

# Nombre max d'entrées en cache
# CACHE_MAX_ENTRIES=1000

# ============================================================================
# Optional: Rate Limiting (si throttler est activé)
# ============================================================================

# Requêtes par minute par IP
# RATE_LIMIT_TRANSLATIONS=100

# ============================================================================
# Monitoring & Logging (optionnel)
# ============================================================================

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Activer Prometheus metrics
# ENABLE_PROMETHEUS=false

# ============================================================================
# Application Configuration
# ============================================================================

# Port du serveur NestJS
PORT=3001

# Node environment
NODE_ENV=development
